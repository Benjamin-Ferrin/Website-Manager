<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= business ? 'Edit Business' : 'New Business' %></title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <header class="admin-header">
    <strong>Platform Admin</strong>
    <nav><a href="/admin">Dashboard</a></nav>
  </header>
  <main class="admin-main">
    <h1><%= business ? 'Edit Business' : 'New Business' %></h1>
    <% if (error) { %><p class="error"><%= error %></p><% } %>

    <form method="post" action="<%= business ? '/admin/businesses/' + business.id : '/admin/businesses' %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Name</label>
      <input type="text" name="name" value="<%= business ? business.name : '' %>" required>
      <label>Slug (URL path)</label>
      <input type="text" name="slug" value="<%= business ? business.slug : '' %>" required pattern="[a-z0-9-]+">
      <label>Custom Domain (optional)</label>
      <input type="text" name="domain" value="<%= business && business.domain ? business.domain : '' %>" placeholder="example.com">
      <% if (business) { %>
      <label>Settings (JSON)</label>
      <textarea name="settings" rows="4"><%= JSON.stringify(business.settings || {}, null, 2) %></textarea>
      <% } %>
      <button type="submit">Save</button>
    </form>
  </main>
</body>
</html>
