<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Menu — <%= business.name %></title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <header class="admin-header">
    <strong>Platform Admin</strong>
    <nav><a href="/admin/businesses/<%= business.id %>">← <%= business.name %></a></nav>
  </header>
  <main class="admin-main">
    <h1>Menu Editor</h1>
    <form method="post" action="/admin/businesses/<%= business.id %>/menu" id="menu-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div id="menu-items">
        <% const menuItems = items.length ? items : [{ label: 'Home', url: '/' }]; %>
        <% menuItems.forEach(function(item) { %>
        <div class="menu-row">
          <input type="text" name="label" value="<%= item.label %>" placeholder="Label">
          <input type="text" name="url" value="<%= item.url %>" placeholder="URL (/about)">
          <button type="button" class="remove-row">Remove</button>
        </div>
        <% }); %>
      </div>
      <button type="button" id="add-menu-item">+ Add item</button>
      <button type="submit">Save menu</button>
    </form>
  </main>
  <script src="/js/admin.js"></script>
</body>
</html>
